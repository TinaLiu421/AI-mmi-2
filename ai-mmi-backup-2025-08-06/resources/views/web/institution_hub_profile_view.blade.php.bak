        <i class="fa fa-arrow-left"></i> Back to Colleges
    </a>
</div>

<!-- ── HERO ──────────────────────────────────────────────────────────── -->
<div class="ipv2-hero"<?php echo $heroBg; ?>>
    <div class="ipv2-hero-overlay"></div>
    <div class="ipv2-hero-pattern"></div>

    <?php if ($_str_score > 0): ?>
    <div class="ipv2-hero-strength">
        <div class="ipv2-strength-bar-wrap"><div class="ipv2-strength-bar-fill" style="width:<?php echo $_str_score; ?>%"></div></div>
        Profile <?php echo $_str_score; ?>%
    </div>
    <?php endif; ?>

    <div class="ipv2-hero-inner">
        <!-- Logo -->
        <div class="ipv2-hero-logo">
            <?php if (!empty($logoSrc)): ?>
            <img src="<?php echo $logoSrc; ?>" alt="<?php echo htmlspecialchars($instName, ENT_QUOTES); ?>"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
            <span class="ipv2-hero-logo-ph" style="display:none"><?php echo htmlspecialchars($_logoInitials, ENT_QUOTES); ?></span>
            <?php else: ?>
            <span class="ipv2-hero-logo-ph"><?php echo htmlspecialchars($_logoInitials, ENT_QUOTES); ?></span>
            <?php endif; ?>
        </div>

        <!-- Name + tags + description + CTA -->
        <div class="ipv2-hero-text">
            <h1 class="ipv2-hero-name"><?php echo $instName; ?></h1>

            <div class="ipv2-hero-tags">
                <span class="ipv2-hero-tag"><?php echo htmlspecialchars($catLabel, ENT_QUOTES); ?></span>
                <?php if (!empty($city) || !empty($country)): ?>
                <span class="ipv2-hero-tag"><i class="fa fa-map-marker"></i> <?php echo htmlspecialchars(trim($city . ($city && $country ? ', ' : '') . $country), ENT_QUOTES); ?></span>
                <?php endif; ?>
                <?php if (!empty($schoolPhases)): ?>
