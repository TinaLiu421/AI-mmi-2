                        <?php if (!empty($cToefl)):    ?><tr><td class="req-label">TOEFL iBT</td><td><?php echo $cToefl; ?></td></tr><?php endif; ?>
                        <?php if (!empty($cCambridge)):?><tr><td class="req-label">Cambridge</td><td><?php echo $cCambridge; ?></td></tr><?php endif; ?>
