    <!-- ── FACILITIES TAB ─────────────────────────────────────── -->
    <?php if ($showFacilities): ?>
    <div class="ipv2-tab-panel<?php echo $firstTab === 'facilities' ? ' active' : ''; ?>" id="ipv2-tab-facilities">
        <div class="ipv2-gallery-grid">
            <?php foreach ($_pv_gallery as $_gi => $_gf): ?>
            <div class="ipv2-gallery-item" onclick="ipv2OpenLightbox(<?php echo $_gi; ?>)">
                <img src="/upload/inst_gallery/<?php echo htmlspecialchars(basename($_gf), ENT_QUOTES); ?>" alt="Campus photo <?php echo $_gi + 1; ?>" loading="lazy">
            </div>
            <?php endforeach; ?>
        </div>
