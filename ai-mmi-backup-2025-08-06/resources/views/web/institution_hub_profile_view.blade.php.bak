        <?php if (!empty($fees)): ?>
        <div class="ipv2-text-content" style="margin-bottom:14px"><?php echo ipv2_textToHtml($fees); ?></div>
        <?php endif; ?>
        <?php if (!empty($keyDates)): ?>
        <div class="ipv2-text-content">
            <?php echo ipv2_keyDatesToHtml($keyDates); ?>
        </div>
