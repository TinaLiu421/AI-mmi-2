                        <?php if (!empty($cAppFee)):  ?><tr><td class="req-label">Application</td><td><?php echo $cAppFee; ?></td></tr><?php endif; ?>
                        <?php if (!empty($cOshc)):    ?><tr><td class="req-label">OSHC</td><td><?php echo $cOshc; ?></td></tr><?php endif; ?>
                        <?php if (!empty($cLiving)):  ?><tr><td class="req-label">Living Costs</td><td><?php echo $cLiving; ?></td></tr><?php endif; ?>
                    </table>
                </div>
