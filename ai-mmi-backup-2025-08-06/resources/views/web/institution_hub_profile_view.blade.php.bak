<!-- ── CONTENT ───────────────────────────────────────────────────────── -->
<div class="ipv2-content">

    <!-- ── OVERVIEW TAB ──────────────────────────────────────── -->
    <?php if ($showOverview): ?>
    <div class="ipv2-tab-panel<?php echo $firstTab === 'overview' ? ' active' : ''; ?>" id="ipv2-tab-overview">
        <div class="ipv2-overview-layout">

            <!-- ═══ LEFT: main content ═══ -->
            <div class="ipv2-overview-main">

                <!-- About snippet -->
                <?php $_aboutSrc = !empty($description) ? strip_tags($description) : (!empty($summary) ? strip_tags($summary) : ''); ?>
                <?php if (!empty($_aboutSrc)): ?>
                <div class="ipv2-summ-card">
                    <p class="ipv2-summ-title"><i class="fa fa-info-circle"></i> About <?php echo $instName; ?></p>
                    <div class="ipv2-about-snippet">
                        <?php
                        $_aParas = preg_split('/\n{2,}/', trim($_aboutSrc));
                        if (count($_aParas) === 1) $_aParas = array_values(array_filter(array_map('trim', preg_split('/\n/', $_aboutSrc))));
                        $_show = array_slice($_aParas, 0, 2);
                        $_more = array_slice($_aParas, 2);
                        foreach ($_show as $_p): if (empty(trim($_p))) continue; ?>
                        <p><?php echo htmlspecialchars(trim($_p), ENT_QUOTES); ?></p>
                        <?php endforeach; ?>
                        <?php if (!empty($_more)): ?>
                        <div id="ipv2-about-more" style="display:none">
                            <?php foreach ($_more as $_p): if (empty(trim($_p))) continue; ?>
                            <p><?php echo htmlspecialchars(trim($_p), ENT_QUOTES); ?></p>
                            <?php endforeach; ?>
                        </div>
                        <button class="ipv2-see-more-btn" onclick="var m=document.getElementById('ipv2-about-more');m.style.display=m.style.display==='none'?'block':'none';this.textContent=m.style.display==='block'?'Show less \u25b2':'Read more \u25be'">Read more &#9662;</button>
                        <?php endif; ?>
                    </div>
                </div>
                <?php endif; ?>

                <!-- Entry Requirements at a Glance -->
                <?php
                $_req_en = []; $_req_ac = [];
                if (!empty($admission)) {
                    foreach (preg_split('/\r?\n/', $admission) as $_rl) {
                        $_rl = trim($_rl);
                        if (!$_rl || $_rl[0] !== '-') continue;
                        $_ri = ltrim($_rl, '-•· ');
                        if (preg_match('/^(IELTS(?:\s+Academic)?|PTE(?:\s+Academic)?|TOEFL(?:\s+iBT)?|Cambridge(?:\s+English)?|Duolingo|OET)\s*[:\-]\s*(.+)/i', $_ri, $_rm)) {
                            $key = strtoupper(preg_replace('/\s+Academic|\s+iBT/i','',trim($_rm[1])));
                            if (!isset($_req_en[$key]) && count($_req_en) < 5) $_req_en[$key] = trim($_rm[2]);
                        } elseif (count($_req_ac) < 4 && preg_match('/^(Year\s+\d|ATAR|GPA|Bachelor|Completed|Secondary|High\s+School|Australian\s+Year|Minimum age)/i', $_ri)) {
                            $_req_ac[] = $_ri;
                        }
                    }
                }
                ?>
                <?php if (!empty($_req_en) || !empty($_req_ac)): ?>
                <div class="ipv2-summ-card">
                    <p class="ipv2-summ-title"><i class="fa fa-check-square-o"></i> Entry Requirements</p>
                    <?php if (!empty($_req_en)): ?>
                    <p style="font-size:.72em;font-weight:700;color:#1a5ca8;text-transform:uppercase;letter-spacing:.07em;margin:0 0 7px">English Proficiency (Minimum)</p>
                    <?php foreach ($_req_en as $_test => $_score): ?>
                    <div class="ipv2-req-row">
                        <span class="ipv2-req-label"><?php echo htmlspecialchars($_test, ENT_QUOTES); ?></span>
                        <span class="ipv2-req-val"><?php echo htmlspecialchars($_score, ENT_QUOTES); ?></span>
                    </div>
                    <?php endforeach; ?>
                    <?php endif; ?>
                    <?php if (!empty($_req_ac)): ?>
                    <p style="font-size:.72em;font-weight:700;color:#1a5ca8;text-transform:uppercase;letter-spacing:.07em;margin:10px 0 7px">Academic Requirements</p>
                    <?php foreach ($_req_ac as $_ar): ?>
                    <div class="ipv2-req-row"><span class="ipv2-req-val" style="min-width:unset"><?php echo htmlspecialchars($_ar, ENT_QUOTES); ?></span></div>
                    <?php endforeach; ?>
                    <?php endif; ?>
                    <?php if ($showAdmission): ?>
                    <div style="margin-top:12px">
                        <button class="ipv2-see-more-btn" onclick="document.querySelector('[data-tab=\'ipv2-tab-admission\']').click()"><i class="fa fa-arrow-right"></i> Full admission requirements</button>
                    </div>
                    <?php endif; ?>
                </div>
                <?php elseif ($showAdmission): ?>
                <div class="ipv2-summ-card">
                    <p class="ipv2-summ-title"><i class="fa fa-clipboard"></i> Admission Requirements</p>
                    <p style="color:#64748b;font-size:.93em;margin:0 0 12px">Requirements are available — see the Admission tab for full details.</p>
                    <button class="ipv2-see-more-btn" onclick="document.querySelector('[data-tab=\'ipv2-tab-admission\']').click()" style="font-size:.9em"><i class="fa fa-arrow-right"></i> View Admission Requirements</button>
                </div>
                <?php endif; ?>

                <!-- Fees Overview -->
                <?php
                $_fee_lines = [];
                if (!empty($fees)) {
                    $_in_tuition = false;
                    foreach (preg_split('/\r?\n/', $fees) as $_fl) {
                        $_fl = trim($_fl);
                        if (!$_fl) { $_in_tuition = false; continue; }
                        if (preg_match('/^(TUITION|COURSE\s+FEES|TUITION\s+\/)/i', $_fl)) { $_in_tuition = true; continue; }
                        if ($_in_tuition && $_fl[0] === '-') {
                            $_fee_lines[] = ltrim($_fl, '-•· ');
                            if (count($_fee_lines) >= 6) break;
                        } elseif ($_in_tuition && preg_match('/^[A-Z]{3,}/', $_fl) && !empty($_fee_lines)) {
                            break;
                        } elseif ($_in_tuition && preg_match('/^[A-Z]{3,}/', $_fl)) {
                            $_in_tuition = false;
                        }
                    }
                }
                ?>
                <?php if (!empty($_fee_lines) || !empty($annualFeesRange)): ?>
                <div class="ipv2-summ-card">
                    <p class="ipv2-summ-title"><i class="fa fa-dollar"></i> Fees Overview</p>
                    <?php if (!empty($annualFeesRange)): ?>
                    <div style="background:#f0fdf4;border-radius:9px;padding:10px 14px;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center;gap:8px">
                        <span style="font-size:.88em;color:#334155;font-weight:600">Annual Fees Range</span>
                        <span style="color:#16a34a;font-weight:800;font-size:.97em"><?php echo htmlspecialchars($annualFeesRange, ENT_QUOTES); ?></span>
                    </div>
                    <?php endif; ?>
                    <?php foreach ($_fee_lines as $_fee): ?>
                    <div class="ipv2-fee-row">
                        <?php if (preg_match('/^(.+?):\s*(AUD|USD|\$|€|£|\d)(.+)$/i', $_fee, $_fm)): ?>
                        <span class="ipv2-fee-label"><?php echo htmlspecialchars(trim($_fm[1]), ENT_QUOTES); ?></span>
                        <span class="ipv2-fee-val"><?php echo htmlspecialchars(trim($_fm[2].$_fm[3]), ENT_QUOTES); ?></span>
                        <?php else: ?>
                        <span style="color:#334155;font-size:.9em;flex:1"><?php echo htmlspecialchars($_fee, ENT_QUOTES); ?></span>
                        <?php endif; ?>
                    </div>
                    <?php endforeach; ?>
                    <?php if ($showFees): ?>
                    <div style="margin-top:12px">
                        <button class="ipv2-see-more-btn" onclick="document.querySelector('[data-tab=\'ipv2-tab-fees\']').click()"><i class="fa fa-arrow-right"></i> Full fees &amp; key dates</button>
                    </div>
                    <?php endif; ?>
                </div>
                <?php elseif ($showFees): ?>
                <div class="ipv2-summ-card">
                    <p class="ipv2-summ-title"><i class="fa fa-money"></i> Fees &amp; Costs</p>
                    <p style="color:#64748b;font-size:.93em;margin:0 0 12px">Fee details available — see the Fees tab for the full breakdown.</p>
                    <button class="ipv2-see-more-btn" onclick="document.querySelector('[data-tab=\'ipv2-tab-fees\']').click()" style="font-size:.9em"><i class="fa fa-arrow-right"></i> View Fees &amp; Dates</button>
                </div>
                <?php endif; ?>

                <!-- Key Features -->
                <?php $factRows = ipv2_factRow('Boarding available', $hasBoarding) . ipv2_factRow('School bus service', $hasSchoolBus) . ipv2_factRow('Scholarships available', $hasScholarships) . ipv2_factRow('Chinese language support', $hasChinese) . ipv2_factRow('Extra language programs', $hasExtraLangs); ?>
                <?php if (!empty($factRows)): ?>
                <div class="ipv2-summ-card">
                    <p class="ipv2-summ-title"><i class="fa fa-star-o"></i> School Features</p>
                    <div class="ipv2-facts-grid"><?php echo $factRows; ?></div>
                </div>
                <?php endif; ?>

                <!-- Curriculum & Qualifications -->
                <?php if (!empty($curriculum) || !empty($examBoards) || !empty($qualificationsAwarded)): ?>
                <div class="ipv2-summ-card">
                    <p class="ipv2-summ-title"><i class="fa fa-graduation-cap"></i> Curriculum &amp; Qualifications</p>
                    <?php if (!empty($curriculum)): ?>
                    <div style="margin-bottom:10px">
                        <p style="font-size:.72em;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.06em;margin:0 0 5px">Curriculum</p>
                        <?php echo ipv2_pillList($curriculum); ?>
                    </div>
                    <?php endif; ?>
                    <?php if (!empty($examBoards)): ?>
                    <div style="margin-bottom:10px">
                        <p style="font-size:.72em;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.06em;margin:0 0 5px">Exam Boards</p>
                        <?php echo ipv2_pillList($examBoards, 'ipv2-pill-green'); ?>
                    </div>
                    <?php endif; ?>
                    <?php if (!empty($qualificationsAwarded)): ?>
                    <div>
                        <p style="font-size:.72em;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.06em;margin:0 0 5px">Qualifications Awarded</p>
                        <?php echo ipv2_pillList($qualificationsAwarded, 'ipv2-pill-purple'); ?>
                    </div>
                    <?php endif; ?>
                </div>
                <?php endif; ?>

