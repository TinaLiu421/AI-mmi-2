                    </div>
                    <?php endif; ?>
                    <?php if (!empty($socialLinks)): ?>
                    <div class="ipv2-ql-row" style="flex-wrap:wrap">
                        <span class="ipv2-ql-icon"><i class="fa fa-share-alt"></i></span>
                        <span class="ipv2-ql-label">Social</span>
                        <div class="ipv2-ql-social" style="flex:1">
                            <?php foreach ($socialLinks as $_slKey => $_slUrl): if (empty($_slUrl)) continue;
                                $_slInfo = $_socialIcons[$_slKey] ?? ['fa fa-link', ucfirst($_slKey)]; ?>
                            <a href="<?php echo htmlspecialchars((string)$_slUrl, ENT_QUOTES); ?>" target="_blank" rel="noopener noreferrer">
                                <i class="<?php echo htmlspecialchars($_slInfo[0], ENT_QUOTES); ?>"></i> <?php echo htmlspecialchars($_slInfo[1], ENT_QUOTES); ?>
