@extends('web.common')

@push('css')
<style>
/* ── Full-width layout: hide chat panel, expand info-area ── */
main.page-body .info-area{width:100%!important;float:none!important;background:#f1f5f9!important;background-image:none!important;min-height:100vh!important}
main.page-body .info-area::before{display:none!important}
main.page-body .page-content{margin-right:0!important}
body{background:#f1f5f9!important}
main.page-body .chat-area{display:none!important}
main.page-body .mobile-chat-button{display:none!important}
/* =====================================================
   AI-mmi Institution Profile v2
   ===================================================== */
.ipv2-page{--clr-accent:#1a5ca8;--clr-dark:#0f172a;--clr-mid:#334155;--clr-light:#f8fafc;--clr-border:#e2e8f0;--clr-success:#10b981;--clr-danger:#ef4444;font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;font-size:16px;background:#f1f5f9;min-height:100vh;padding-bottom:60px}

/* Hero */
.ipv2-hero{position:relative;height:340px;background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 100%);background-size:cover;background-position:center}
.ipv2-hero-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,.25) 0%,rgba(0,0,0,.72) 100%)}
.ipv2-hero-inner{position:relative;z-index:2;max-width:1100px;margin:0 auto;padding:0 24px 32px;display:flex;align-items:flex-end;gap:22px;height:100%;box-sizing:border-box}
.ipv2-hero-logo{width:84px;height:84px;border-radius:14px;background:#fff;display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;box-shadow:0 4px 20px rgba(0,0,0,.35)}
.ipv2-hero-logo img{width:100%;height:100%;object-fit:contain}
.ipv2-hero-logo-ph{font-size:2em;font-weight:700;color:var(--clr-accent);text-transform:uppercase}
.ipv2-hero-text{flex:1;min-width:0}
.ipv2-hero-name{color:#fff;font-size:clamp(1.4em,3vw,2.1em);font-weight:700;margin:0 0 7px;line-height:1.2}
.ipv2-hero-tags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:9px}
.ipv2-hero-tag{background:rgba(255,255,255,.13);color:#e2e8f0;border:1px solid rgba(255,255,255,.22);border-radius:20px;padding:2px 10px;font-size:.82em;backdrop-filter:blur(4px)}
.ipv2-hero-desc{color:rgba(255,255,255,.78);font-size:.95em;line-height:1.6;margin:0 0 13px;max-width:620px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.ipv2-hero-actions{display:flex;gap:9px;flex-wrap:wrap}
.ipv2-btn-primary{background:var(--clr-accent);color:#fff;border:none;border-radius:8px;padding:8px 17px;font-size:.85em;font-weight:600;cursor:pointer;text-decoration:none;transition:background .2s;display:inline-block}
.ipv2-btn-primary:hover{background:#1447a0;color:#fff}
.ipv2-btn-outline{background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.32);border-radius:8px;padding:8px 17px;font-size:.85em;font-weight:600;cursor:pointer;text-decoration:none;transition:background .2s;display:inline-block}
.ipv2-btn-outline:hover{background:rgba(255,255,255,.2);color:#fff}
.ipv2-btn-accent{background:#f59e0b;color:#1e293b;border:none;border-radius:8px;padding:8px 17px;font-size:.85em;font-weight:700;cursor:pointer;text-decoration:none;transition:background .2s;display:inline-block}
.ipv2-btn-accent:hover{background:#d97706;color:#1e293b}
/* profile strength — hidden from public; kept for reference */
.ipv2-hero-strength{display:none!important}

/* Key stats strip */
.ipv2-stats-strip{background:#fff;border-bottom:2px solid var(--clr-border);padding:0 24px}
.ipv2-stats-strip-inner{max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;gap:0;border-top:none}
.ipv2-stat-item{display:flex;align-items:center;gap:9px;padding:13px 22px 13px 0;margin-right:4px;border-right:1px solid var(--clr-border)}
.ipv2-stat-item:last-child{border-right:none}
.ipv2-stat-icon{width:32px;height:32px;border-radius:8px;background:#eff6ff;display:flex;align-items:center;justify-content:center;color:var(--clr-accent);font-size:.85em;flex-shrink:0}
.ipv2-stat-body{display:flex;flex-direction:column;min-width:0}
.ipv2-stat-label{font-size:.7em;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#94a3b8;line-height:1}
.ipv2-stat-value{font-size:.9em;font-weight:600;color:#1e293b;margin-top:2px;white-space:nowrap}
.ipv2-stat-value a{color:var(--clr-accent);text-decoration:none}
.ipv2-stat-value a:hover{text-decoration:underline}
@media(max-width:640px){.ipv2-stats-strip{padding:0 14px}.ipv2-stat-item{padding:10px 14px 10px 0}.ipv2-stat-value{font-size:.82em}}
/* Info bar */
.ipv2-info-bar{background:#f8fafc;border-bottom:1px solid var(--clr-border);padding:6px 24px;display:flex;align-items:center;justify-content:flex-end;gap:18px;font-size:.78em;color:#64748b}
.ipv2-claim-link{color:var(--clr-accent);font-weight:600;text-decoration:none}
.ipv2-claim-link:hover{text-decoration:underline}

/* Tabs */
.ipv2-tabs-outer{background:#fff;border-bottom:2px solid var(--clr-border);position:sticky;top:0;z-index:100;box-shadow:0 2px 8px rgba(0,0,0,.04)}
.ipv2-tabs{max-width:1100px;margin:0 auto;padding:0 20px;display:flex;overflow-x:auto;scrollbar-width:none}
.ipv2-tabs::-webkit-scrollbar{display:none}
.ipv2-tab-btn{background:none;border:none;border-bottom:3px solid transparent;padding:14px 18px;font-size:.95em;font-weight:500;color:#64748b;cursor:pointer;white-space:nowrap;transition:color .2s,border-color .2s;margin-bottom:-2px}
.ipv2-tab-btn:hover{color:var(--clr-accent)}
.ipv2-tab-btn.active{color:var(--clr-accent);border-bottom-color:var(--clr-accent);font-weight:600}

/* Content */
.ipv2-content{max-width:1100px;margin:0 auto;padding:26px 24px}
.ipv2-tab-panel{display:none}
.ipv2-tab-panel.active{display:block}

/* Back */
.ipv2-back{max-width:1100px;margin:0 auto;padding:14px 24px 0}
.ipv2-back-link{color:#64748b;text-decoration:none;font-size:.83em;display:inline-flex;align-items:center;gap:5px}
.ipv2-back-link:hover{color:var(--clr-accent)}

/* Overview: content left + sticky sidebar right */
.ipv2-overview-layout{display:grid;grid-template-columns:1fr 310px;gap:20px;align-items:start}
@media(max-width:900px){.ipv2-overview-layout{grid-template-columns:1fr}}
.ipv2-overview-main{display:flex;flex-direction:column;gap:16px}
.ipv2-overview-sidebar{display:flex;flex-direction:column;gap:16px}

/* Quick Look — clean white sidebar card */
.ipv2-quicklook{background:#fff;border-radius:14px;border:1px solid #dde6f8;box-shadow:0 2px 14px rgba(0,32,101,0.07);padding:18px 20px;color:#334155}
.ipv2-ql-title{font-size:.7em;letter-spacing:.1em;text-transform:uppercase;color:#94a3b8;margin:0 0 12px;font-weight:700}
.ipv2-ql-row{display:flex;align-items:flex-start;gap:9px;padding:7px 0;border-bottom:1px solid #f1f5f9;font-size:.9em}
.ipv2-ql-row:last-child{border-bottom:none}
.ipv2-ql-icon{width:18px;text-align:center;flex-shrink:0;margin-top:2px;color:#1a5ca8;font-size:.85em}
.ipv2-ql-label{color:#64748b;min-width:75px;flex-shrink:0;font-size:.86em}
.ipv2-ql-value{color:#1e293b;flex:1;word-break:break-word;font-weight:500}
.ipv2-ql-link{color:#1a5ca8;text-decoration:none;font-weight:500}
.ipv2-ql-link:hover{text-decoration:underline}
.ipv2-ql-social{display:flex;gap:5px;flex-wrap:wrap;margin-top:3px}
.ipv2-ql-social a{display:inline-flex;align-items:center;gap:3px;background:#eff6ff;border:1px solid #bfdbfe;border-radius:6px;padding:3px 9px;font-size:.8em;color:#1a5ca8;text-decoration:none;transition:background .15s}
.ipv2-ql-social a:hover{background:#dbeafe;color:#1447a0}

/* Facts panel */
.ipv2-facts-panel{display:flex;flex-direction:column;gap:14px}
.ipv2-facts-card{background:#fff;border-radius:12px;padding:16px 18px;box-shadow:0 1px 4px rgba(0,0,0,.06)}
.ipv2-facts-card-title{font-size:.76em;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:#94a3b8;margin:0 0 11px}
.ipv2-facts-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px 18px}
@media(max-width:480px){.ipv2-facts-grid{grid-template-columns:1fr}}
.ipv2-fact-row{display:flex;align-items:center;gap:7px;font-size:.91em;color:#334155;padding:4px 0}
.ipv2-fact-yes{color:#10b981}
.ipv2-fact-no{color:#ef4444}
.ipv2-fact-na{color:#cbd5e1}
.ipv2-info-rows{display:flex;flex-direction:column;gap:0}
.ipv2-info-row{display:flex;align-items:baseline;gap:10px;font-size:.91em;padding:7px 0;border-bottom:1px solid #f1f5f9}
.ipv2-info-row:last-child{border-bottom:none}
.ipv2-info-label{color:#64748b;min-width:150px;flex-shrink:0}
.ipv2-info-val{color:#1e293b;font-weight:500;flex:1}
/* Summary cards (requirements, fees, about) */
.ipv2-summ-card{background:#fff;border-radius:14px;border:1px solid #dde6f8;box-shadow:0 2px 12px rgba(0,32,101,0.06);padding:20px 22px}
.ipv2-summ-title{font-size:.72em;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:#94a3b8;margin:0 0 14px;display:flex;align-items:center;gap:6px}
.ipv2-summ-title i{color:#1a5ca8}
.ipv2-req-row{display:flex;align-items:baseline;gap:10px;padding:6px 0;border-bottom:1px solid #f8fafc;font-size:.91em}
.ipv2-req-row:last-child{border-bottom:none}
.ipv2-req-label{color:#64748b;min-width:95px;flex-shrink:0;font-size:.87em}
.ipv2-req-val{color:#1e293b;font-weight:600;flex:1}
.ipv2-fee-row{display:flex;align-items:baseline;gap:10px;padding:7px 0;border-bottom:1px solid #f8fafc;font-size:.92em}
.ipv2-fee-row:last-child{border-bottom:none}
.ipv2-fee-label{color:#475569;flex:1;font-size:.9em}
.ipv2-fee-val{color:#0f172a;font-weight:700;white-space:nowrap}
.ipv2-fee-val.green{color:#16a34a}
/* About snippet */
.ipv2-about-snippet{font-size:.96em;color:#334155;line-height:1.75}
.ipv2-about-snippet p{margin:0 0 .8em}
.ipv2-about-snippet p:last-child{margin:0}
.ipv2-see-more-btn{background:none;border:none;color:#1a5ca8;font-size:.84em;font-weight:600;cursor:pointer;padding:4px 0;margin-top:6px;display:inline-flex;align-items:center;gap:4px}
.ipv2-see-more-btn:hover{text-decoration:underline}
/* Inline Google Map */
.ipv2-map-wrap{border-radius:10px;overflow:hidden;border:1px solid #e2e8f0;margin-top:12px;line-height:0}
.ipv2-map-wrap iframe{display:block;width:100%;height:210px;border:none}

/* Address box — keep for backward compat but hide (address is in sidebar map card now) */
.ipv2-address-box{display:none}

/* Pills */
.ipv2-pill-list{display:flex;flex-wrap:wrap;gap:5px}
.ipv2-pill{background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;border-radius:20px;padding:3px 12px;font-size:.84em;font-weight:500}
.ipv2-pill-green{background:#f0fdf4;color:#16a34a;border-color:#bbf7d0}
.ipv2-pill-purple{background:#faf5ff;color:#7c3aed;border-color:#ddd6fe}
.ipv2-pill-gray{background:#f8fafc;color:#64748b;border-color:#e2e8f0}

/* About accordions */
.ipv2-accordion{background:#fff;border-radius:12px;margin-bottom:10px;box-shadow:0 1px 4px rgba(0,0,0,.05);overflow:hidden}
.ipv2-accordion summary{display:flex;justify-content:space-between;align-items:center;padding:16px 18px;cursor:pointer;font-weight:600;font-size:1em;color:#1e293b;list-style:none;user-select:none}
.ipv2-accordion summary::-webkit-details-marker{display:none}
.ipv2-accordion summary::after{content:'▾';font-size:.82em;color:#94a3b8;transition:transform .2s}
.ipv2-accordion[open] summary::after{transform:rotate(-180deg)}
.ipv2-accordion-body{padding:2px 18px 18px;color:#475569;font-size:.93em;line-height:1.65;border-top:1px solid #f1f5f9}
.ipv2-accordion-body p{margin:0 0 .9em;font-size:1em;line-height:1.65;color:#374151}
.ipv2-accordion-body p:last-child{margin-bottom:0}
.ipv2-desc-stat{font-weight:700;color:#1e40af}

/* About cards grid */
.ipv2-about-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;margin-top:8px}
.ipv2-about-card{background:#f8fafc;border:1px solid var(--clr-border);border-radius:10px;padding:14px 16px}
.ipv2-about-card-title{font-size:.75em;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:#94a3b8;margin:0 0 9px}

/* Text content (admission/fees/dates blobs) */
.ipv2-text-content{font-size:.96em;line-height:1.7;color:#334155;background:#fff;border-radius:12px;padding:22px 24px;box-shadow:0 1px 4px rgba(0,0,0,.05)}
.ipv2-text-content h4.inst-section-subhead{font-size:.76em;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--clr-accent);margin:22px 0 10px;padding:9px 14px;background:#eff6ff;border-left:4px solid var(--clr-accent);border-radius:0 6px 6px 0;border-bottom:none}
.ipv2-text-content h4.inst-section-subhead:first-child{margin-top:0}
.ipv2-text-content ul.inst-section-list{list-style:none;padding:0;margin:0 0 14px}
.ipv2-text-content ul.inst-section-list li{padding:7px 10px 7px 28px;position:relative;font-size:.93em;color:#334155;border-bottom:1px solid #f1f5f9}
.ipv2-text-content ul.inst-section-list li:last-child{border-bottom:none}
.ipv2-text-content ul.inst-section-list li::before{content:'›';position:absolute;left:9px;top:6px;color:var(--clr-accent);font-weight:700;font-size:1.1em;line-height:1.4}
.ipv2-text-content ul.inst-section-list li.inst-see-website{color:#94a3b8;font-style:italic}
.ipv2-text-content ul.inst-section-list li.inst-see-website::before{content:none}
.ipv2-text-content ul.inst-section-list li.inst-contact-admissions{color:#2563eb;background:#eff6ff;border-radius:6px;padding:6px 10px 6px 32px;font-size:.88em;font-style:normal}
.ipv2-text-content ul.inst-section-list li.inst-contact-admissions::before{content:none}
.ipv2-text-content ul.inst-section-list li.inst-contact-admissions i{margin-right:5px;opacity:.7}
.inst-dates-list li.inst-date-item{display:flex;align-items:center;gap:12px;padding:9px 10px;flex-wrap:wrap}
.ipv2-text-content ul.inst-dates-list li.inst-date-item::before{content:none;display:none}
.inst-date-badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:.78em;font-weight:700;white-space:nowrap;flex-shrink:0}
.inst-date-badge-red{background:#fee2e2;color:#b91c1c}
.inst-date-badge-green{background:#dcfce7;color:#15803d}
.inst-date-badge-blue{background:#dbeafe;color:#1d4ed8}
.inst-date-desc{font-size:.93em;color:#334155}

/* Gallery */
.ipv2-gallery-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:12px}
.ipv2-gallery-item{border-radius:10px;overflow:hidden;aspect-ratio:16/10;background:#e2e8f0;cursor:pointer}
.ipv2-gallery-item img{width:100%;height:100%;object-fit:cover;transition:transform .3s;display:block}
.ipv2-gallery-item:hover img{transform:scale(1.04)}

/* Courses (reuse old classes with small tweaks) */
.inst-course-card{background:#fff;border-radius:12px;margin-bottom:10px;box-shadow:0 1px 4px rgba(0,0,0,.06);overflow:hidden;transition:box-shadow .2s}
.inst-course-card.is-open,.inst-course-card:hover{box-shadow:0 4px 16px rgba(0,0,0,.1)}
.inst-course-header{display:flex;align-items:center;gap:14px;padding:16px 18px;cursor:pointer;flex-wrap:wrap}
.inst-course-logo-wrap{flex-shrink:0}
.inst-course-logo{width:42px;height:42px;border-radius:8px;object-fit:contain;background:#f8fafc;padding:2px}
.inst-course-logo-placeholder{width:42px;height:42px;border-radius:8px;background:#eff6ff;display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--clr-accent);font-size:.9em}
.inst-course-title-block{flex:1;min-width:160px}
.inst-course-code-row{display:flex;align-items:center;gap:8px;margin-bottom:3px}
.inst-course-code{background:#f1f5f9;color:#64748b;border-radius:5px;padding:1px 7px;font-size:.79em;font-weight:600}
.inst-course-location{color:#94a3b8;font-size:.82em}
.inst-course-name{font-weight:600;font-size:1em;color:#1e293b;line-height:1.3}
.inst-course-level-badge{display:inline-block;background:#eff6ff;color:var(--clr-accent);border-radius:20px;padding:2px 9px;font-size:.77em;font-weight:600;margin-top:4px}
.inst-course-meta-summary{display:flex;flex-wrap:wrap;gap:8px;flex-shrink:0}
.inst-course-meta-pill{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:5px 10px;text-align:center;min-width:80px}
.meta-pill-label{display:block;font-size:.69em;color:#94a3b8;font-weight:600;letter-spacing:.05em;text-transform:uppercase}
.meta-pill-value{display:block;font-size:.88em;color:#1e293b;font-weight:600;margin-top:1px}
.inst-tuition-value{color:#10b981}
.inst-course-expand-btn{background:none;border:1px solid #e2e8f0;border-radius:8px;padding:7px 13px;font-size:.84em;font-weight:600;color:#64748b;cursor:pointer;white-space:nowrap;flex-shrink:0}
.inst-course-expand-btn:hover{background:#f1f5f9;color:var(--clr-accent)}
.inst-course-details{padding:0 18px 18px;border-top:1px solid #f1f5f9}
.inst-detail-section{margin-top:14px}
.inst-detail-section h4{font-size:.85em;font-weight:700;color:#334155;margin:0 0 8px;text-transform:uppercase;letter-spacing:.06em}
.inst-overview-text{font-size:.94em;color:#475569;line-height:1.75;margin:0}
.inst-req-table{width:100%;border-collapse:collapse;font-size:.91em}
.inst-req-table tr{border-bottom:1px solid #f1f5f9}
.inst-req-table tr:last-child{border-bottom:none}
.inst-req-table td{padding:5px 8px;color:#334155;vertical-align:top}
.req-label{color:#94a3b8;white-space:nowrap;width:100px;font-weight:500}
.inst-scholarship-note h4{color:#d97706}
.inst-detail-apply-row{text-align:right;margin-top:12px}
.inst-apply-btn{display:inline-block;background:var(--clr-accent);color:#fff;border-radius:8px;padding:8px 18px;font-size:.9em;font-weight:600;text-decoration:none}
.inst-apply-btn:hover{background:#1447a0;color:#fff}
.inst-course-filters{margin-bottom:14px;display:flex;flex-wrap:wrap;gap:10px;align-items:center}
.inst-course-search{padding:9px 14px;border:1px solid #e2e8f0;border-radius:8px;font-size:.94em;outline:none;background:#fff;min-width:200px;flex:1;max-width:320px}
.inst-course-search:focus{border-color:var(--clr-accent)}
.ipv2-level-filters{display:flex;flex-wrap:wrap;gap:5px}
.ipv2-level-btn{background:#fff;border:1px solid #e2e8f0;border-radius:20px;padding:5px 14px;font-size:.83em;font-weight:600;color:#64748b;cursor:pointer;transition:all .15s;white-space:nowrap}
.ipv2-level-btn:hover{border-color:var(--clr-accent);color:var(--clr-accent)}
.ipv2-level-btn.active{background:var(--clr-accent);border-color:var(--clr-accent);color:#fff}
.inst-no-results,.ipv2-empty{text-align:center;padding:40px 20px;color:#94a3b8}
.ipv2-empty i,.inst-no-results i{font-size:2em;margin-bottom:10px;display:block}
.ipv2-text-content ul.inst-section-list li.inst-see-website{color:#94a3b8;font-style:italic}
.ipv2-text-content ul.inst-section-list li.inst-see-website::before{content:none}
.ipv2-text-content ul.inst-section-list li.inst-contact-admissions{color:#2563eb;background:#eff6ff;border-radius:6px;padding:6px 10px 6px 32px;font-size:.88em;font-style:normal}
.ipv2-text-content ul.inst-section-list li.inst-contact-admissions::before{content:none}
.ipv2-text-content ul.inst-section-list li.inst-contact-admissions i{margin-right:5px;opacity:.7}
.inst-course-meta-pill:has(.meta-pill-label){}

/* Responsive */
@media(max-width:600px){
  .ipv2-hero{height:290px}
  .ipv2-hero-inner{padding:0 14px 22px;gap:14px}
  .ipv2-hero-logo{width:66px;height:66px}
  .ipv2-hero-name{font-size:1.15em}
  .ipv2-content{padding:14px 14px}
  .ipv2-tab-btn{padding:11px 11px;font-size:.8em}
  .ipv2-hero-strength{display:none}
  .ipv2-stat-item{padding:12px 16px 12px 0}
  .ipv2-stat-value{font-size:.92em}
}

/* ============================================================
   VISUAL POLISH PACK — professional edu-site standards
   (IDP / QS / Hotcourses inspired)
   ============================================================ */

/* Slightly warmer page bg */
.ipv2-page{background:#eef2f7}

/* Hero: taller, dot-texture pattern, bottom gradient bar */
.ipv2-hero{height:400px}
.ipv2-hero-pattern{position:absolute;inset:0;z-index:1;pointer-events:none;
  background-image:radial-gradient(rgba(255,255,255,.065) 1px,transparent 1px);
  background-size:26px 26px}
.ipv2-hero-bar{position:absolute;bottom:0;left:0;right:0;height:4px;z-index:5;
  background:linear-gradient(90deg,#3b82f6 0%,#818cf8 50%,#a78bfa 100%)}
/* Keep inner above pattern */
.ipv2-hero-inner{z-index:4}

/* Logo: ring effect + slightly larger */
.ipv2-hero-logo{width:96px;height:96px;border-radius:18px;
  box-shadow:0 0 0 4px rgba(255,255,255,.22),0 8px 32px rgba(0,0,0,.5)}
.ipv2-hero-logo-ph{font-size:2.2em;font-weight:800;letter-spacing:-.02em}

/* Name: heavier weight */
.ipv2-hero-name{font-weight:800;letter-spacing:-.02em}

/* Tags: slightly more visible */
.ipv2-hero-tag{background:rgba(255,255,255,.2);border-color:rgba(255,255,255,.3);
  font-size:.83em;padding:3px 12px}

/* Hero desc: slightly more opaque */
.ipv2-hero-desc{color:rgba(255,255,255,.88)}

/* Buttons: gradient + depth shadow */
.ipv2-btn-primary{
  background:linear-gradient(135deg,#1a5ca8 0%,#2563eb 100%);
  box-shadow:0 3px 14px rgba(37,99,235,.38);
  padding:10px 20px;font-size:.88em}
.ipv2-btn-primary:hover{background:linear-gradient(135deg,#1447a0 0%,#1d4fd8 100%);color:#fff}
.ipv2-btn-accent{
  background:linear-gradient(135deg,#f59e0b 0%,#ea7c0a 100%);
  box-shadow:0 3px 14px rgba(245,158,11,.38);
  padding:10px 20px;font-size:.88em;color:#fff}
.ipv2-btn-accent:hover{background:linear-gradient(135deg,#d97706 0%,#c2640a 100%);color:#fff}

/* Stats strip: bigger numbers, soft shadow */
.ipv2-stats-strip{border-bottom:none;box-shadow:0 3px 16px rgba(0,0,0,.07)}
.ipv2-stat-item{padding:18px 28px 18px 0}
.ipv2-stat-value{font-size:1.05em;font-weight:700;color:#0f172a;margin-top:4px}
.ipv2-stat-label{font-size:.66em;letter-spacing:.1em}
.ipv2-stat-icon{width:38px;height:38px;border-radius:10px;font-size:.9em}
/* Per-icon color tinting */
.ipv2-stat-item:nth-child(1) .ipv2-stat-icon{background:#eff6ff;color:#2563eb}
.ipv2-stat-item:nth-child(2) .ipv2-stat-icon{background:#fef3c7;color:#b45309}
.ipv2-stat-item:nth-child(3) .ipv2-stat-icon{background:#f0fdf4;color:#15803d}

/* Info bar */
.ipv2-info-bar{background:#f8fafc;border-bottom:1px solid #dce3ed}

/* Tabs: slightly bolder active */
.ipv2-tabs-outer{box-shadow:0 3px 16px rgba(0,0,0,.07)}
.ipv2-tab-btn{font-size:.95em;padding:15px 20px;font-weight:600}
.ipv2-tab-btn.active{font-weight:700;border-bottom-width:3px}

/* Accordion: left border accent on open state */
.ipv2-accordion{border-left:3px solid transparent;transition:border-color .2s}
.ipv2-accordion[open]{border-left-color:var(--clr-accent)}
.ipv2-accordion[open] summary{background:linear-gradient(90deg,#f0f7ff,#fff);color:var(--clr-accent)}
.ipv2-accordion summary{transition:background .15s,color .15s}

/* Quick Look sidebar: subtle shadow upgrade only */
.ipv2-quicklook{box-shadow:0 4px 20px rgba(0,32,101,0.10)}
.ipv2-ql-value{font-weight:600}

/* Cards: sharper multi-layer shadow */
.ipv2-facts-card{box-shadow:0 1px 4px rgba(0,0,0,.06),0 4px 16px rgba(0,0,0,.05)}
.ipv2-text-content{box-shadow:0 1px 4px rgba(0,0,0,.06),0 4px 16px rgba(0,0,0,.05)}

/* Subheads: richer accent gradient bg */
.ipv2-text-content h4.inst-section-subhead{
  background:linear-gradient(90deg,#dbeafe,#eff6ff 70%,transparent)}

/* Course cards: border + accent hover */
.inst-course-card{border:1px solid #e4eaf3}
.inst-course-card:hover{border-color:var(--clr-accent);
  box-shadow:0 4px 22px rgba(26,92,168,.13)}

/* Pills: sharper */
.ipv2-pill{font-weight:600}
.ipv2-pill-green{background:#f0fdf4;color:#166534;border-color:#bbf7d0}
</style>
@endpush

@section('content')
<?php
// ── Data extraction ───────────────────────────────────────────────────────────
$_profile  = $_page_data['profile'] ?? [];
$_courses  = $_page_data['courses'] ?? [];
$profileId = (int)($_profile['id'] ?? 0);

// Basic info — strip legal suffixes (Pty Ltd, trading as, Inc, etc.) for display
$_rawInstName = $_profile['institute_name'] ?? 'Institution';
$_rawInstName = preg_replace('/\s*\(trading\s+as\s+[^)]+\)/i', '', $_rawInstName); // remove "(trading as ...)"
$_rawInstName = preg_replace('/\s*\bPty\.?\s+Ltd\.?\b/i', '', $_rawInstName);     // remove "Pty Ltd"
$_rawInstName = preg_replace('/\s*\bPty\.?\b(?=\s*$)/i', '', $_rawInstName);         // remove trailing "Pty"
$_rawInstName = preg_replace('/\s*,?\s*\bLimited\b/i', '', $_rawInstName);            // remove "Limited"
$_rawInstName = preg_replace('/\s*,?\s*\bInc\.?\b(?=\s*$)/i', '', $_rawInstName);    // remove trailing "Inc."
$_rawInstName = trim($_rawInstName);
if (empty($_rawInstName)) $_rawInstName = $_profile['institute_name'] ?? 'Institution';
$instName   = htmlspecialchars($_rawInstName, ENT_QUOTES);
$avatar     = $_profile['avatar'] ?? '';
$websiteUrl = $_profile['website_url'] ?? '';
$country    = $_profile['country'] ?? '';
$category   = $_profile['institution_category'] ?? '';

// New structured fields
$city              = $_profile['city'] ?? '';
$address           = $_profile['address'] ?? '';
$phone             = $_profile['phone'] ?? '';
$bannerImage       = $_profile['banner_image'] ?? '';
$schoolPhases      = $_profile['school_phases'] ?? '';
$annualFeesRange   = $_profile['annual_fees_range'] ?? '';
$prospectusUrl     = $_profile['prospectus_url'] ?? '';
$studentTeacherRatio = $_profile['student_teacher_ratio'] ?? '';
$academicYear      = $_profile['academic_year'] ?? '';
$missionStatement  = $_profile['mission_statement'] ?? '';
$description       = $_profile['description'] ?? '';
$profileStrength   = (int)($_profile['profile_strength'] ?? 0);
$claimedAt         = $_profile['claimed_at'] ?? null;

// JSON arrays
$_ipv2_decode_json = function($raw) {
    if (empty($raw)) return [];
    $d = json_decode($raw, true);
    return is_array($d) ? array_values(array_filter($d)) : [];
};
$curriculum           = $_ipv2_decode_json($_profile['curriculum'] ?? '');
$examBoards           = $_ipv2_decode_json($_profile['exam_boards'] ?? '');
$qualificationsAwarded= $_ipv2_decode_json($_profile['qualifications_awarded'] ?? '');
$languageOfInstruction= $_ipv2_decode_json($_profile['language_of_instruction'] ?? '');
$schoolQualities      = $_ipv2_decode_json($_profile['school_qualities'] ?? '');
$examResults          = $_ipv2_decode_json($_profile['exam_results'] ?? '');

// Social links (JSON object)
$socialLinks = [];
$_slRaw = $_profile['social_links'] ?? '';
if (!empty($_slRaw)) {
    $slDecoded = json_decode($_slRaw, true);
    if (is_array($slDecoded)) $socialLinks = $slDecoded;
}

// Boolean flags (null = unknown, 1 = yes, 0 = no)
$hasBoarding     = isset($_profile['has_boarding']) && $_profile['has_boarding'] !== null ? (int)$_profile['has_boarding'] : null;
$hasSchoolBus    = isset($_profile['has_school_bus']) && $_profile['has_school_bus'] !== null ? (int)$_profile['has_school_bus'] : null;
$hasScholarships = isset($_profile['has_scholarships']) && $_profile['has_scholarships'] !== null ? (int)$_profile['has_scholarships'] : null;
$hasChinese      = isset($_profile['has_chinese_language_support']) && $_profile['has_chinese_language_support'] !== null ? (int)$_profile['has_chinese_language_support'] : null;
$hasExtraLangs   = isset($_profile['has_extra_languages']) && $_profile['has_extra_languages'] !== null ? (int)$_profile['has_extra_languages'] : null;

// Legacy text blobs
$summary   = $_profile['summary']   ?? '';
$admission = $_profile['admission'] ?? '';
$fees      = $_profile['fees']      ?? '';
$keyDates  = $_profile['key_dates'] ?? '';
$programs  = $_profile['programs']  ?? '';

// Logo src
$logoSrc = !empty($avatar) ? '/upload/member_logo/' . htmlspecialchars(basename($avatar), ENT_QUOTES) : '';

// Better initials: first letter of each significant word, up to 3 chars
$_ignoreWords = ['of','and','the','a','an','for','in','at','by','to','&'];
$_nameParts   = preg_split('/[\s\(\)\-\/]+/', $instName, -1, PREG_SPLIT_NO_EMPTY);
$_logoInitials = '';
foreach ($_nameParts as $_p) {
    if (!in_array(strtolower($_p), $_ignoreWords) && preg_match('/\pL/u', $_p)) {
        $_logoInitials .= mb_strtoupper(mb_substr($_p, 0, 1, 'UTF-8'), 'UTF-8');
    }
    if (mb_strlen($_logoInitials, 'UTF-8') >= 3) break;
}
if (empty($_logoInitials)) $_logoInitials = mb_strtoupper(mb_substr($instName, 0, 2, 'UTF-8'), 'UTF-8');

// Gallery
$_pv_gallery = $_ipv2_decode_json($_profile['gallery_json'] ?? '');

// Hero background: banner_image first, then first gallery photo, else gradient
if (!empty($bannerImage)) {
    $heroBg = ' style="background-image:url(\'/upload/inst_gallery/' . htmlspecialchars(basename($bannerImage), ENT_QUOTES) . '\')"';
} elseif (!empty($_pv_gallery)) {
    $heroBg = ' style="background-image:url(\'/upload/inst_gallery/' . htmlspecialchars(basename($_pv_gallery[0]), ENT_QUOTES) . '\')"';
} else {
    $heroBg = '';
}

// Short hero description: word-boundary truncation ≤ 220 chars
$_heroSrc = !empty($description) ? strip_tags($description) : (!empty($summary) ? strip_tags($summary) : '');
if (!empty($_heroSrc) && mb_strlen($_heroSrc, 'UTF-8') > 220) {
    $_heroTrunc = rtrim(preg_replace('/\s+\S*$/u', '', mb_substr($_heroSrc, 0, 221, 'UTF-8')));
    $heroDesc = $_heroTrunc . '…';
} else {
    $heroDesc = $_heroSrc;
}

// Category label
$catLabels = [
    'university'         => 'College',
    'vocational'         => 'VET / Vocational',
    'highschool'         => 'High School',
    'college'            => 'College',
    'language_school'    => 'Language School',
    'primary_school'     => 'Primary School',
    'secondary_school'   => 'Secondary School',
    'international_school'=> 'International School',
    'tutoring'           => 'Tutoring Centre',
    'other'              => 'College',
];
$catLabel = $catLabels[$category] ?? ucwords(str_replace('_', ' ', $category));

// Extract CRICOS / RTO from summary or description (legacy support)
// Regex requires code to start with a digit to avoid matching words like "compliance", "registered"
$_pv_cricos = ''; $_pv_rto = '';
$_pv_src = $summary . ' ' . $description;
if (!empty($_pv_src)) {
    if (preg_match('/\bCRICOS(?:\s+Provider(?:\s+Code)?)?[#:\s]+([0-9][A-Z0-9]{4,9})\b/i', $_pv_src, $_m)) $_pv_cricos = strtoupper($_m[1]);
    if (preg_match('/\bRTO[#:\s]+([0-9]+)/i', $_pv_src, $_m))                                               $_pv_rto    = $_m[1];
}

// Compute profile strength dynamically
$_str_fields = [
    !empty($instName) && $instName !== 'Institution',
    !empty($avatar),
    !empty($websiteUrl),
    !empty($description) || !empty($summary),
    !empty($city) || !empty($country),
    !empty($phone),
    !empty($address),
    !empty($annualFeesRange),
    !empty($curriculum),
    !empty($examBoards),
    !empty($qualificationsAwarded),
    !empty($studentTeacherRatio),
    !empty($missionStatement),
    !empty($schoolQualities),
    !empty($_pv_gallery),
    count($_courses) > 0,
    !empty($socialLinks),
    !empty($admission) || !empty($fees),
];
$_str_score = $profileStrength > 0 ? $profileStrength : (int)(array_sum(array_map('intval', $_str_fields)) / count($_str_fields) * 100);

// Updated date
$updatedAt = $_profile['updated_at'] ?? '';
$updatedLabel = '';
if (!empty($updatedAt)) {
    try { $updatedLabel = (new DateTime($updatedAt))->format('M Y'); }
    catch(\Throwable $e) { $updatedLabel = ''; }
}

// Helper functions
if (!function_exists('ipv2_textToHtml')) {
    function ipv2_textToHtml(string $text): string {
        if (empty(trim($text))) return '';
        $lines = explode("\n", $text);
        $out = ''; $inList = false;
        foreach ($lines as $line) {
            $line = trim($line);
            if ($line === '') { if ($inList) { $out .= '</ul>'; $inList = false; } continue; }
            if (preg_match('/^[A-Z0-9 \/()\-&:]{6,}:?\s*$/', $line) && $line === strtoupper($line)) {
                if ($inList) { $out .= '</ul>'; $inList = false; }
                $out .= '<h4 class="inst-section-subhead">' . htmlspecialchars(rtrim($line, ':'), ENT_QUOTES) . '</h4>';
            } elseif (str_starts_with($line, '- ') || str_starts_with($line, '• ')) {
                if (!$inList) { $out .= '<ul class="inst-section-list">'; $inList = true; }
                $_li_text = ltrim($line, '-•· ');
                // Auto-upgrade old 'see website' placeholders to actionable contact prompt
                if (preg_match('/see\s+(institution\s+|the\s+|enrol\s+page\s+on\s+the\s+|[\w\s]+\s+on\s+(the\s+)?)?website/i', $_li_text)) {
                    $_li_text = 'Contact admissions for current details';
                    $out .= '<li class="inst-contact-admissions"><i class="fa fa-envelope-o"></i> ' . htmlspecialchars($_li_text, ENT_QUOTES) . '</li>';
                } elseif (preg_match('/contact\s+admissions\s+for\s+current/i', $_li_text)) {
                    $out .= '<li class="inst-contact-admissions"><i class="fa fa-envelope-o"></i> ' . htmlspecialchars($_li_text, ENT_QUOTES) . '</li>';
                } else {
                    $out .= '<li>' . htmlspecialchars($_li_text, ENT_QUOTES) . '</li>';
                }
            } else {
                if ($inList) { $out .= '</ul>'; $inList = false; }
                $out .= '<p>' . htmlspecialchars($line, ENT_QUOTES) . '</p>';
            }
        }
        if ($inList) $out .= '</ul>';
        return $out;
    }
}
// Keep old name for backward compat
if (!function_exists('textToHtmlBlocks')) {
    function textToHtmlBlocks(string $text): string { return ipv2_textToHtml($text); }
}
// Description renderer — splits into paragraphs and auto-bolds key stats/numbers
if (!function_exists('ipv2_descriptionToHtml')) {
    function ipv2_descriptionToHtml(string $text): string {
        if (empty(trim($text))) return '';
        // Split into paragraphs on double (or single) newlines
        $paras = preg_split('/\n{2,}/', trim($text));
        if (count($paras) === 1) {
            $paras = array_values(array_filter(array_map('trim', preg_split('/\n/', $text))));
        }
        $out = '';
        foreach ($paras as $para) {
            $para = trim($para);
            if (empty($para)) continue;
            $safe = htmlspecialchars($para, ENT_QUOTES);
            // Bold numbers with common units
            $safe = preg_replace('/\b(\d[\d,]*\+?)\s*(students?|countries?|campuses?|staff|researchers?|graduates?|programs?|courses?|years?|nationalities|faculties|schools)\b/i', '<strong class="ipv2-desc-stat">$1 $2</strong>', $safe);
            // Bold rankings, percentages, QS references
            $safe = preg_replace('/\b(top\s+\d+%?|No\.\s*\d+|#\s*\d+|QS\s+Five\s+Stars?|QS\s+[\w\s]+?\d+)(?=[\s,\.\!\?]|$)/i', '<strong class="ipv2-desc-stat">$1</strong>', $safe);
            $safe = preg_replace('/\b(\d+(?:\.\d+)?%)\b/', '<strong class="ipv2-desc-stat">$1</strong>', $safe);
            $out .= '<p>' . $safe . '</p>';
        }
        return $out ?: '<p>' . htmlspecialchars($text, ENT_QUOTES) . '</p>';
    }
}
// Special renderer for key dates — extracts "DD Month YYYY — Description" patterns into visual badges
if (!function_exists('ipv2_keyDatesToHtml')) {
    function ipv2_keyDatesToHtml(string $text): string {
        if (empty(trim($text))) return '';
        $lines = explode("\n", $text);
        $out = ''; $inList = false;
        foreach ($lines as $line) {
            $line = trim($line);
            if ($line === '') { if ($inList) { $out .= '</ul>'; $inList = false; } continue; }
            if (preg_match('/^[A-Z0-9 \/()\-&:]{6,}:?\s*$/', $line) && $line === strtoupper($line)) {
                if ($inList) { $out .= '</ul>'; $inList = false; }
                $out .= '<h4 class="inst-section-subhead">' . htmlspecialchars(rtrim($line, ':'), ENT_QUOTES) . '</h4>';
            } elseif (str_starts_with($line, '- ') || str_starts_with($line, '• ')) {
                $item = ltrim($line, '-•· ');
                // Detect "DD Month YYYY — Description" or "DD Month YYYY: Description"
                if (preg_match('/^(\d{1,2}\s+\w+\s+\d{4})\s*[—–\-:]\s*(.*)/u', $item, $m)) {
                    if (!$inList) { $out .= '<ul class="inst-section-list inst-dates-list">'; $inList = true; }
                    try { $badge = (new DateTime($m[1]))->format('j M Y'); }
                    catch(\Throwable $e) { $badge = $m[1]; }
                    $desc = $m[2];
                    $isDeadline = preg_match('/deadline|close|last\s+day|due|acceptance/i', $desc);
                    $isOpen     = preg_match('/open|begin|start|launch/i', $desc);
                    $cls = $isDeadline ? 'inst-date-badge-red' : ($isOpen ? 'inst-date-badge-green' : 'inst-date-badge-blue');
                    $out .= '<li class="inst-date-item"><span class="inst-date-badge ' . $cls . '">' . htmlspecialchars($badge, ENT_QUOTES) . '</span><span class="inst-date-desc">' . htmlspecialchars($desc, ENT_QUOTES) . '</span></li>';
                } else {
                    if (!$inList) { $out .= '<ul class="inst-section-list inst-dates-list">'; $inList = true; }
                    $out .= '<li>' . htmlspecialchars($item, ENT_QUOTES) . '</li>';
                }
            } else {
                if ($inList) { $out .= '</ul>'; $inList = false; }
                $out .= '<p>' . htmlspecialchars($line, ENT_QUOTES) . '</p>';
            }
        }
        if ($inList) $out .= '</ul>';
        return $out;
    }
}
if (!function_exists('courseLevel')) {
    function courseLevel(string $name): string {
        $n = strtolower($name);
        if (str_contains($n,'doctor')||str_contains($n,'phd'))          return 'Doctoral';
        if (str_contains($n,'master')||str_contains($n,'graduate dip')) return 'Postgraduate';
        if (str_contains($n,'bachelor'))     return 'Undergraduate';
        if (str_contains($n,'advanced dip')) return 'Advanced Diploma';
        if (str_contains($n,'diploma'))      return 'Diploma';
        if (str_contains($n,'certificate iv')||str_contains($n,'cert iv')) return 'Certificate IV';
        if (str_contains($n,'certificate iii')) return 'Certificate III';
        if (str_contains($n,'certificate'))  return 'Certificate';
        return 'Program';
    }
}

// Helper: render a boolean fact row (only shows when available/true)
function ipv2_factRow(string $label, $val): string {
    if (!$val) return '';  // Only show features the school actually has
    return '<div class="ipv2-fact-row"><i class="fa fa-check-circle ipv2-fact-yes"></i><span>' . htmlspecialchars($label, ENT_QUOTES) . '</span></div>';
}

// Helper: render a pill list
function ipv2_pillList(array $items, string $cls = ''): string {
    if (empty($items)) return '';
    $out = '<div class="ipv2-pill-list">';
    foreach ($items as $item) {
        $out .= '<span class="ipv2-pill ' . htmlspecialchars($cls, ENT_QUOTES) . '">' . htmlspecialchars((string)$item, ENT_QUOTES) . '</span>';
    }
    return $out . '</div>';
}

// Determine which tabs to show
$showOverview  = !empty($city) || !empty($phone) || !empty($address) || !empty($country) || !empty($annualFeesRange) || !empty($schoolPhases) || !empty($curriculum) || !empty($examBoards) || !empty($hasBoarding) || !empty($hasChinese) || !empty($studentTeacherRatio);
$showAbout     = !empty($summary) || !empty($description) || !empty($missionStatement) || !empty($schoolQualities) || !empty($curriculum) || !empty($examBoards);
$showPrograms  = !empty($_courses);
$showAdmission = !empty($admission);
$showFees      = !empty($fees) || !empty($keyDates);
$showFacilities= !empty($_pv_gallery);

// First active tab
$firstTab = $showOverview ? 'overview' : ($showAbout ? 'about' : ($showPrograms ? 'programs' : ($showAdmission ? 'admission' : ($showFees ? 'fees' : 'facilities'))));

// Social icon map
$_socialIcons = [
    'facebook'  => ['fa fa-facebook',  'Facebook'],
    'instagram' => ['fa fa-instagram', 'Instagram'],
    'youtube'   => ['fa fa-youtube',   'YouTube'],
    'linkedin'  => ['fa fa-linkedin',  'LinkedIn'],
    'twitter'   => ['fa fa-twitter',   'Twitter'],
    'wechat'    => ['fa fa-weixin',    'WeChat'],
    'bilibili'  => ['fa fa-play-circle','Bilibili'],
    'website'   => ['fa fa-globe',     'Website'],
];
?>

