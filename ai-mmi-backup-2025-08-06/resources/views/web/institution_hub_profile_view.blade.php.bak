    <!-- Empty state if no data at all -->
    <?php if (!$showOverview && !$showAbout && !$showPrograms && !$showAdmission && !$showFees && !$showFacilities): ?>
    <div class="ipv2-empty" style="padding:80px 20px">
        <i class="fa fa-building-o"></i>
        <p style="font-size:1.1em;font-weight:600;color:#334155;margin-bottom:6px">Profile Coming Soon</p>
        <p style="font-size:.88em">This institution's profile is being set up. Check back soon for full details.</p>
    </div>
    <?php endif; ?>

</div><!-- /.ipv2-content -->

<!-- Lightbox overlay -->
<div id="ipv2-lightbox" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:9999;align-items:center;justify-content:center;flex-direction:column">
    <button onclick="document.getElementById('ipv2-lightbox').style.display='none'" style="position:absolute;top:16px;right:22px;background:none;border:none;color:#fff;font-size:2em;cursor:pointer;z-index:2">&times;</button>
    <button id="ipv2-lb-prev" onclick="ipv2LbNav(-1)" style="position:absolute;left:16px;background:none;border:none;color:#fff;font-size:2.5em;cursor:pointer;z-index:2">&#x2039;</button>
    <img id="ipv2-lb-img" src="" alt="" style="max-width:90vw;max-height:85vh;object-fit:contain;border-radius:8px">
    <button id="ipv2-lb-next" onclick="ipv2LbNav(1)" style="position:absolute;right:16px;background:none;border:none;color:#fff;font-size:2.5em;cursor:pointer;z-index:2">&#x203A;</button>
    <div id="ipv2-lb-caption" style="color:#94a3b8;font-size:.82em;margin-top:12px"></div>
</div>

</div><!-- /.ipv2-page -->
@endsection

@push('scripts')
<script>
// ── Tab switching ─────────────────────────────────────────────────────────────
document.querySelectorAll('.ipv2-tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.ipv2-tab-btn').forEach(function(b){ b.classList.remove('active'); });
        document.querySelectorAll('.ipv2-tab-panel').forEach(function(p){ p.classList.remove('active'); });
        btn.classList.add('active');
        var panel = document.getElementById(btn.getAttribute('data-tab'));
        if (panel) panel.classList.add('active');
    });
});

// ── Course expand/collapse ────────────────────────────────────────────────────
function ipv2ToggleCourse(header) {
    var card    = header.closest('.inst-course-card');
    var details = card.querySelector('.inst-course-details');
    var btn     = card.querySelector('.inst-course-expand-btn');
    if (!details) return;
    var isOpen  = details.style.display !== 'none';
    details.style.display = isOpen ? 'none' : '';
    if (btn) btn.textContent = isOpen ? 'View Details ▾' : 'Close ▴';
    card.classList.toggle('is-open', !isOpen);
}

// ── Course search filter ──────────────────────────────────────────────────────
var ipv2Search = document.getElementById('ipv2-course-search');
var _ipv2ActiveLevel = '';
function _ipv2FilterCourses() {
    var q = (ipv2Search ? ipv2Search.value.toLowerCase().trim() : '');
    var cards = document.querySelectorAll('#ipv2-course-list .inst-course-card');
    var visible = 0;
    cards.forEach(function(card) {
        var matchQ = !q || (card.getAttribute('data-search') || '').indexOf(q) !== -1;
        var matchL = !_ipv2ActiveLevel || (card.getAttribute('data-level') || '') === _ipv2ActiveLevel;
        var show = matchQ && matchL;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
    });
    var nr = document.getElementById('ipv2-no-results');
    if (nr) nr.style.display = (visible === 0) ? '' : 'none';
}
if (ipv2Search) ipv2Search.addEventListener('input', _ipv2FilterCourses);
document.querySelectorAll('.ipv2-level-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.ipv2-level-btn').forEach(function(b){b.classList.remove('active');});
        this.classList.add('active');
        _ipv2ActiveLevel = this.getAttribute('data-level') || '';
        _ipv2FilterCourses();
    });
});

// ── Gallery lightbox ──────────────────────────────────────────────────────────
var _ipv2Gallery = <?php echo json_encode(array_values(array_map('basename', $_pv_gallery))); ?>;
var _ipv2LbIdx = 0;
function ipv2OpenLightbox(idx) {
    if (!_ipv2Gallery.length) return;
    _ipv2LbIdx = idx;
    ipv2LbShow();
    var lb = document.getElementById('ipv2-lightbox');
    lb.style.display = 'flex';
}
function ipv2LbShow() {
    var img = document.getElementById('ipv2-lb-img');
    var cap = document.getElementById('ipv2-lb-caption');
    if (img) img.src = '/upload/inst_gallery/' + _ipv2Gallery[_ipv2LbIdx];
    if (cap) cap.textContent = (_ipv2LbIdx + 1) + ' / ' + _ipv2Gallery.length;
    var prev = document.getElementById('ipv2-lb-prev');
    var next = document.getElementById('ipv2-lb-next');
    if (prev) prev.style.display = _ipv2Gallery.length > 1 ? '' : 'none';
    if (next) next.style.display = _ipv2Gallery.length > 1 ? '' : 'none';
}
function ipv2LbNav(dir) {
    _ipv2LbIdx = (_ipv2LbIdx + dir + _ipv2Gallery.length) % _ipv2Gallery.length;
    ipv2LbShow();
}
// Close lightbox on overlay click
document.addEventListener('DOMContentLoaded', function() {
    var lb = document.getElementById('ipv2-lightbox');
    if (lb) {
        lb.addEventListener('click', function(e) {
            if (e.target === lb) lb.style.display = 'none';
        });
    }
});
// Keyboard navigation for lightbox
document.addEventListener('keydown', function(e) {
    var lb = document.getElementById('ipv2-lightbox');
    if (!lb || lb.style.display === 'none') return;
    if (e.key === 'Escape') lb.style.display = 'none';
    if (e.key === 'ArrowLeft')  ipv2LbNav(-1);
    if (e.key === 'ArrowRight') ipv2LbNav(1);
});
</script>
@endpush
