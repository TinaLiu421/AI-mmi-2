                        <span class="ipv2-ql-label">Location</span>
                        <span class="ipv2-ql-value"><?php echo htmlspecialchars(implode(', ', array_filter([$city, $country])), ENT_QUOTES); ?></span>
                    </div>
                    <?php endif; ?>
                    <?php if (!empty($schoolPhases)): ?>
                    <div class="ipv2-ql-row">
                        <span class="ipv2-ql-icon"><i class="fa fa-graduation-cap"></i></span>
                        <span class="ipv2-ql-label">Phases</span>
                        <span class="ipv2-ql-value"><?php echo htmlspecialchars($schoolPhases, ENT_QUOTES); ?></span>
