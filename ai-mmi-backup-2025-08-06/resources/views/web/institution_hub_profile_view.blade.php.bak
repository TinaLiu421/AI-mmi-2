                        <span class="ipv2-ql-label">Phone</span>
                        <span class="ipv2-ql-value"><a href="tel:<?php echo htmlspecialchars(preg_replace('/[^0-9+]/','',$phone),ENT_QUOTES); ?>" class="ipv2-ql-link"><?php echo htmlspecialchars($phone, ENT_QUOTES); ?></a></span>
                    </div>
                    <?php endif; ?>
