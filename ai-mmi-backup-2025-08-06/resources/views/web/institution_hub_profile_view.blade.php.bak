                <?php if (!empty($cScholarship)): ?>
                <div class="inst-detail-section inst-scholarship-note"><h4><i class="fa fa-star"></i> Scholarships</h4><p><?php echo nl2br(htmlspecialchars($cScholarship, ENT_QUOTES)); ?></p></div>
                <?php endif; ?>
                <div class="inst-detail-apply-row">
                    <a href="<?php echo htmlspecialchars($_page_base_url . '/apply?institution=' . urlencode($instName) . '&course=' . urlencode($_course['name'] ?? ''), ENT_QUOTES); ?>" class="inst-apply-btn">Create Application <i class="fa fa-arrow-right"></i></a>
                </div>
            </div>
            <?php endif; ?>
        </div>
        <?php endforeach; ?>
        </div>
        <div id="ipv2-no-results" style="display:none" class="ipv2-empty">
            <i class="fa fa-search"></i><p>No programs match your search.</p>
        </div>
    </div>
    <?php endif; ?>

    <!-- ── ADMISSION TAB ──────────────────────────────────────── -->
    <?php if ($showAdmission): ?>
    <div class="ipv2-tab-panel<?php echo $firstTab === 'admission' ? ' active' : ''; ?>" id="ipv2-tab-admission">
        <div class="ipv2-text-content"><?php echo ipv2_textToHtml($admission); ?></div>
    </div>
    <?php endif; ?>

    <!-- ── FEES & KEY DATES TAB ───────────────────────────────── -->
    <?php if ($showFees): ?>
